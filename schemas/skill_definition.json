{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Skill Definition",
  "description": "Schema for a single executable AI Skill generated by Phase 5 (AI Skill Generator).",
  "type": "object",
  "required": ["skill_id", "version", "name", "purpose", "domain", "supported_versions", "supported_modules", "input", "output", "prompt", "validation"],
  "additionalProperties": false,
  "properties": {
    "skill_id": { "type": "string", "pattern": "^skill_\\w+_\\d{4}$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "name": { "type": "string" },
    "purpose": { "type": "string" },
    "domain": { "type": "string" },
    "subdomain": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "supported_versions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
    },
    "supported_modules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "description": "Other skill IDs required by this skill" }
    },
    "scope": {
      "type": "object",
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "responsibilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "input": {
      "type": "object",
      "required": ["parameters"],
      "properties": {
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "description"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean" },
              "default": {},
              "example": {}
            }
          }
        },
        "context": { "type": "object" }
      }
    },
    "output": {
      "type": "object",
      "required": ["type", "schema"],
      "properties": {
        "type": { "type": "string" },
        "schema": { "type": "object", "description": "JSON Schema for the output" },
        "examples": { "type": "array" }
      }
    },
    "prompt": {
      "type": "object",
      "required": ["system", "template"],
      "properties": {
        "system": { "type": "string" },
        "template": { "type": "string" },
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "source": { "type": "string", "enum": ["input", "context", "knowledge_base", "source_code"] }
            }
          }
        },
        "few_shot_examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "input": {},
              "output": {}
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "validator"],
            "properties": {
              "field": { "type": "string" },
              "validator": { "type": "string" },
              "params": { "type": "object" }
            }
          }
        },
        "required_output_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "best_practices": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "troubleshooting": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symptom": { "type": "string" },
          "cause": { "type": "string" },
          "solution": { "type": "string" }
        }
      }
    },
    "related_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Source registry IDs that support this skill's claims"
    }
  }
}
